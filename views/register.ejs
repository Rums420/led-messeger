<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Регистрация</title>
        <link rel="stylesheet" href="css/style_register.css">
        
        <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
        <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-auth.js"></script>
        <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
        <link rel="icon" href="imges/favicon.png" type="image/png">
    </head>
    <body>
        <div class="main">
            <img src="imges/favicon.png" alt="Логотип" id="logo">
            <h1><p class="register"><b>Регистрация</b></p></h1>

            <form id="login_form" method="post">
                <!-- ========= Имя пользователя ========= -->
                <div class="name_input"> 
                    <p class="text">Имя пользователя</p>
                    <div class="input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#000000"><path d="M12 2a5 5 0 1 0 5 5 5 5 0 0 0-5-5zm0 8a3 3 0 1 1 3-3 3 3 0 0 1-3 3zm9 11v-1a7 7 0 0 0-7-7h-4a7 7 0 0 0-7 7v1h2v-1a5 5 0 0 1 5-5h4a5 5 0 0 1 5 5v1z" fill="#000000"/></svg>
                        <input type="text" name="name" placeholder="Введите имя пользователя">
                    </div> 
                </div>

                <!-- ========= Юзернейм ========= -->

                <div>
                    <p class="text" id="username_text">Введите username</p>
                    <div class="input-wrapper" id="username_emoji">
                        <div id="avatar-circle"><span id="avatar">?</span></div>
                        <div id="picker-container"></div>
                        <input type="text" name="user_name" value="@">
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="2 0 24 24" fill="#000000"><path d="M12 2a5 5 0 1 0 5 5 5 5 0 0 0-5-5zm0 8a3 3 0 1 1 3-3 3 3 0 0 1-3 3zm9 11v-1a7 7 0 0 0-7-7h-4a7 7 0 0 0-7 7v1h2v-1a5 5 0 0 1 5-5h4a5 5 0 0 1 5 5v1z" fill="#000000"/></svg>
                    </div>
                </div>

                <!-- ========= Эл-почта ========= -->

                <div>
                    <p class="text">Электронная почта</p>
                    <div class="input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#000000"><path d="m18.73 5.41-1.28 1L12 10.46 6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64z" fill="#000000"/></svg>
                        <input type="email" name="email" placeholder="Введите электронную почту">
                    </div>
                </div>

                
                <!-- ========= Пароль ========= -->

                <div>
                    <p class="text">Пароль</p>
                    <div class="input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#000000"><path d="M20 12c0-1.103-.897-2-2-2h-1V7c0-2.757-2.243-5-5-5S7 4.243 7 7v3H6c-1.103 0-2 .897-2 2v8c0 1.103.897 2 2 2h12c1.103 0 2-.897 2-2v-8zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v3H9V7z" fill="#000000"/></svg>
                        <input type="password" name="pass" placeholder="Введите пароль">
                    </div>
                </div>

                <!-- ========= Подтвердите пароль ========= -->

                <div>
                    <p class="text">Подтвердите пароль</p>
                    <div class="input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#000000"><path d="M20 12c0-1.103-.897-2-2-2h-1V7c0-2.757-2.243-5-5-5S7 4.243 7 7v3H6c-1.103 0-2 .897-2 2v8c0 1.103.897 2 2 2h12c1.103 0 2-.897 2-2v-8zM9 7c0-1.654 1.346-3 3-3s3 1.346 3 3v3H9V7z" fill="#000000"/></svg>
                        <input type="password" name="repass" placeholder="Подтвердите пароль">
                    </div>

                    <p id="error_text_repass" class="error_text"></p>

                    <label class="text" id="rember-label">
                        <input type="checkbox" id="rember-me" required>
                        <span class="custom_check-box"></span>
                        <span>Rember me</span>
                    </label>
                </div>
                <!-- ========= Кнопка "Зарегистрироваться" ========= -->
                <button id="register_button" type="submit">Зарегесрироваться</button>
            </form>
            
            <div class="error" id="error_div">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" viewBox="0 0 24 24" height="24" class="error_logo"><path d="m13 13h-2v-6h2zm0 4h-2v-2h2zm-1-15c-1.3132 0-2.61358.25866-3.82683.7612-1.21326.50255-2.31565 1.23915-3.24424 2.16773-1.87536 1.87537-2.92893 4.41891-2.92893 7.07107 0 2.6522 1.05357 5.1957 2.92893 7.0711.92859.9286 2.03098 1.6651 3.24424 2.1677 1.21325.5025 2.51363.7612 3.82683.7612 2.6522 0 5.1957-1.0536 7.0711-2.9289 1.8753-1.8754 2.9289-4.4189 2.9289-7.0711 0-1.3132-.2587-2.61358-.7612-3.82683-.5026-1.21326-1.2391-2.31565-2.1677-3.24424-.9286-.92858-2.031-1.66518-3.2443-2.16773-1.2132-.50254-2.5136-.7612-3.8268-.7612z"></path></svg>
                <span class="error_text" id="error_text">Тут будет ошибка ёу</span>
                <div class="error_close"><svg xmlns="http://www.w3.org/2000/svg" width="20" viewBox="0 0 20 20" height="20"><path d="m15.8333 5.34166-1.175-1.175-4.6583 4.65834-4.65833-4.65834-1.175 1.175 4.65833 4.65834-4.65833 4.6583 1.175 1.175 4.65833-4.6583 4.6583 4.6583 1.175-1.175-4.6583-4.6583z"></path></svg></div>
            </div>
        <script src="https://cdn.jsdelivr.net/npm/emoji-mart@latest/dist/browser.js"></script>
        <script type="module" src="js/register.js"></script>
    </body>
</html>